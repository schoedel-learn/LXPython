{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the Learning Experience Platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "customId": { "type": "string", "description": "Unique 8-character user ID" },
        "firstName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "country": { "type": "string" },
        "dateJoined": { "type": "string", "format": "date-time" },
        "birthday": { "type": "string", "description": "MM/DD format" },
        "pythonExperience": { 
          "type": "string", 
          "enum": ["Beginner", "Intermediate", "Advanced", "Expert"] 
        },
        "projectInterests": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["uid", "customId", "firstName", "email", "dateJoined", "pythonExperience"]
    },
    "UserSecret": {
      "title": "UserSecret",
      "description": "Securely stored environment variables for user projects.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "value", "createdAt", "updatedAt"]
    },
    "LearningProgress": {
      "title": "LearningProgress",
      "description": "Tracks a user's mastery of specific Python concepts.",
      "type": "object",
      "properties": {
        "concept": { "type": "string" },
        "masteryLevel": { "type": "number", "description": "0 to 100" },
        "lastInteracted": { "type": "string", "format": "date-time" }
      },
      "required": ["concept", "masteryLevel", "lastInteracted"]
    },
    "CodeAttempt": {
      "title": "CodeAttempt",
      "description": "Stores user's code snippets and execution attempts.",
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "code": { "type": "string" },
        "output": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["topic", "code", "output", "timestamp"]
    },
    "Memory": {
      "title": "Memory",
      "description": "Stores user preferences, milestones, and struggles for AI context.",
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["preference", "milestone", "struggle", "general"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "content", "timestamp"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Stores chat history between the user and the AI.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model", "system", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "ForumPost": {
      "title": "ForumPost",
      "description": "A post in the peer-to-peer learning forum.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "flagged", "hidden"] },
        "replyCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "authorName", "title", "content", "tags", "status", "replyCount", "createdAt", "updatedAt"]
    },
    "ForumReply": {
      "title": "ForumReply",
      "description": "A reply to a forum post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "flagged", "hidden"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "authorName", "content", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/users/{userId}/secrets/{secretId}": {
      "schema": { "$ref": "#/entities/UserSecret" },
      "description": "User's environment variables."
    },
    "/users/{userId}/progress/{progressId}": {
      "schema": { "$ref": "#/entities/LearningProgress" },
      "description": "User's learning progress."
    },
    "/users/{userId}/attempts/{attemptId}": {
      "schema": { "$ref": "#/entities/CodeAttempt" },
      "description": "User's code attempts."
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": { "$ref": "#/entities/Memory" },
      "description": "User's learning memories and preferences."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "User's chat history."
    },
    "/forumPosts/{postId}": {
      "schema": { "$ref": "#/entities/ForumPost" },
      "description": "Peer-to-peer forum posts."
    },
    "/forumPosts/{postId}/replies/{replyId}": {
      "schema": { "$ref": "#/entities/ForumReply" },
      "description": "Replies to a forum post."
    }
  }
}
